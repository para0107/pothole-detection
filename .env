# ─────────────────────────────────────────────
# PostgreSQL / PostGIS
# ─────────────────────────────────────────────
POSTGRES_DB=cluj_monitor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=costincnva2016
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full connection URL (used by SQLAlchemy in backend/database.py)
DATABASE_URL=postgresql://postgres:costincnva2016@localhost:5432/cluj_monitor

# ─────────────────────────────────────────────
# City context
# ─────────────────────────────────────────────
CITY_NAME=Cluj-Napoca
CITY_LAT=46.7712
CITY_LON=23.6236
CITY_BBOX=46.7344,23.5260,46.8080,23.7212

# ─────────────────────────────────────────────
# Pipeline paths
# ─────────────────────────────────────────────
RAW_FOOTAGE_DIR=data/raw/footage
RAW_GPS_DIR=data/raw/gps_logs
FRAMES_DIR=data/processed/frames
METADATA_DIR=data/processed/metadata
WEIGHTS_DIR=ml/weights

# ─────────────────────────────────────────────
# Model weights filenames
# ─────────────────────────────────────────────
RTDETR_WEIGHTS=rtdetr_l_rdd2022.pt
RTDETR_CLUJ_WEIGHTS=rtdetr_l_cluj.pt
EFFICIENTNET_WEIGHTS=efficientnet_b3_depth.pt
XGBOOST_WEIGHTS=xgboost_severity.json

# ─────────────────────────────────────────────
# Detection settings
# ─────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.5
NMS_IOU_THRESHOLD=0.45
FRAME_SAMPLE_RATE=0.5
IMAGE_SIZE=640

# ─────────────────────────────────────────────
# Severity / depth settings
# ─────────────────────────────────────────────
DEPTH_CONFIDENCE_THRESHOLD=0.4
SURROUNDING_DENSITY_RADIUS_M=50
DEDUP_CLUSTER_RADIUS_M=2

# ─────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────
PIPELINE_RUN_HOUR=22
PIPELINE_RUN_MINUTE=0

# ─────────────────────────────────────────────
# External APIs
# ─────────────────────────────────────────────
NOMINATIM_USER_AGENT=cluj-urban-monitor/1.0
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# ─────────────────────────────────────────────
# FastAPI backend
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log